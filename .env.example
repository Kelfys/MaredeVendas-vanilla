# Conexão direta (migrations: supabase db push --db-url)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ulpjsxmilumqedkkfuqw.supabase.co:5432/postgres

# Pooler (Prisma / apps server-side — opcional)
