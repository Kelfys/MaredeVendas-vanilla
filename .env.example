# Referência para CLI Supabase (migrations) — não é lido pelo app em runtime.
# O frontend usa js/config.js (chave publishable / anon).
# Guias Next.js (@supabase/ssr), Prisma e @supabase/server do dashboard NÃO se aplicam a este repo.

# --- Frontend (dashboard Supabase / Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://ulpjsxmilumqedkkfuqw.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua_chave_aqui

# --- CLI / backend (nunca commitar valores reais) ---
SUPABASE_URL=https://ulpjsxmilumqedkkfuqw.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_sua_chave_aqui
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_SECRET_KEY=
